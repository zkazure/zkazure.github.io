<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Org on My New Hugo Site</title><link>https://zkazure.github.io/tags/org/</link><description>Recent content in Org on My New Hugo Site</description><generator>Hugo</generator><language>en</language><lastBuildDate>Thu, 06 Mar 2025 16:37:16 +0800</lastBuildDate><atom:link href="https://zkazure.github.io/tags/org/index.xml" rel="self" type="application/rss+xml"/><item><title>Org Grammar</title><link>https://zkazure.github.io/posts/org-grammar/</link><pubDate>Thu, 06 Mar 2025 00:00:00 +0000</pubDate><guid>https://zkazure.github.io/posts/org-grammar/</guid><description>&lt;p>check out the manual with &lt;code>M-x org-info&lt;/code>&lt;/p>
&lt;h2 id="frontmatter">
 frontmatter
 &lt;a class="heading-link" href="#frontmatter">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h2>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-org" data-lang="org">&lt;span class="line">&lt;span class="cl">&lt;span class="cs">#+title&lt;/span>&lt;span class="c">: org mode in doom emacs&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="cs">#+description&lt;/span>&lt;span class="c">: an document to demonstrate org mode.&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="cs">#+author&lt;/span>&lt;span class="c">: zka-win&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;pre tabindex="0">&lt;code class="language-nil" data-lang="nil">* head 1
** 2
*** 3
&lt;/code>&lt;/pre>&lt;h2 id="headline">
 Headline
 &lt;a class="heading-link" href="#headline">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h2>
&lt;p>&lt;code>z z&lt;/code>: scoll to center
&lt;code>SPC m h&lt;/code>: create a healine under this current healine
&lt;code>SPC m i&lt;/code>: create item
&lt;code>C-RET&lt;/code>: insert the same item.
&lt;code>TAB&lt;/code>: to flod and unfold.
&lt;code>S-TAB&lt;/code>: unfold.
&lt;code>z c&lt;/code>: close
&lt;code>z o&lt;/code>: open
&lt;code>z M&lt;/code>: close all
&lt;code>z R&lt;/code>: open all
&lt;code>g j/k&lt;/code>: go to the next same level
&lt;code>g h/l&lt;/code>: go to the next or last level.
&lt;code>C-RET&lt;/code>: the new level the same as the current level
&lt;code>M-h/l&lt;/code>: change the level&lt;/p></description></item><item><title>summary</title><link>https://zkazure.github.io/posts/org-summary/</link><pubDate>Wed, 05 Feb 2025 00:00:00 +0000</pubDate><guid>https://zkazure.github.io/posts/org-summary/</guid><description>&lt;h2 id="introduction">
 Introduction
 &lt;a class="heading-link" href="#introduction">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h2>
&lt;p>please ignore the &amp;lsquo;,&amp;rsquo; at the beggining.&lt;/p>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-org" data-lang="org">&lt;span class="line">&lt;span class="cl">&lt;span class="cs">#+TITLE&lt;/span>&lt;span class="c">: No matter uppercase or not&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="cs">#+AUTHOR&lt;/span>&lt;span class="c">: me&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h2 id="heading">
 Heading
 &lt;a class="heading-link" href="#heading">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h2>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-org" data-lang="org">&lt;span class="line">&lt;span class="cl">&lt;span class="gh">*&lt;/span>&lt;span class="gs"> the first heading&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="gu">**&lt;/span> second
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="gu">***&lt;/span> third
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="gu">**&lt;/span>&lt;span class="err"> TODO&lt;/span> every heading can be a TODO
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h2 id="annotation">
 Annotation
 &lt;a class="heading-link" href="#annotation">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h2>
&lt;p>&lt;strong>bold&lt;/strong> &lt;em>italic&lt;/em> &lt;span class="underline">underline&lt;/span> &lt;del>delete&lt;/del> &lt;code>code&lt;/code> &lt;code>code&lt;/code>&lt;/p>
&lt;h2 id="list">
 List
 &lt;a class="heading-link" href="#list">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h2>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-org" data-lang="org">&lt;span class="line">&lt;span class="cl">itemize
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">- &lt;/span>item1
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">+ &lt;/span>item2
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;ul>
&lt;li>item&lt;/li>
&lt;li>item&lt;/li>
&lt;/ul>
&lt;!--listend-->
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-org" data-lang="org">&lt;span class="line">&lt;span class="cl">enumerate
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">1.&lt;/span> item-1
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">2)&lt;/span> item-2
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">A. item-A
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">B) item-B
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;ol>
&lt;li>first&lt;/li>
&lt;li>second&lt;/li>
&lt;li>aa&lt;/li>
&lt;li>bb&lt;/li>
&lt;/ol>
&lt;!--listend-->
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-org" data-lang="org">&lt;span class="line">&lt;span class="cl">&lt;span class="k">- [ ]&lt;/span> not started
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">- &lt;/span>[-] in process
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">- [X]&lt;/span> finished
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;ul>
&lt;li>&lt;input disabled="" type="checkbox"> not started&lt;/li>
&lt;li>[-] in process&lt;/li>
&lt;li>&lt;input checked="" disabled="" type="checkbox"> finished&lt;/li>
&lt;/ul>
&lt;h2 id="links">
 Links
 &lt;a class="heading-link" href="#links">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h2>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-org" data-lang="org">&lt;span class="line">&lt;span class="cl">[[&lt;span class="na">https://google.com&lt;/span>][&lt;span class="nt">name&lt;/span>]]
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">[[&lt;span class="na">picture path&lt;/span>]]
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;p>&lt;a href="https://google.com" class="external-link" target="_blank" rel="noopener">google&lt;/a>&lt;/p></description></item><item><title>Difference of the format in the org-mind-map</title><link>https://zkazure.github.io/posts/format-in-org-mind-map/</link><pubDate>Thu, 06 Mar 2025 00:00:00 +0000</pubDate><guid>https://zkazure.github.io/posts/format-in-org-mind-map/</guid><description>&lt;h2 id="raster">
 Raster
 &lt;a class="heading-link" href="#raster">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h2>
&lt;h3 id="gif--graphics-interchange-format">
 GIF(Graphics Interchange Format)
 &lt;a class="heading-link" href="#gif--graphics-interchange-format">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h3>
&lt;ul>
&lt;li>low quality&lt;/li>
&lt;li>support animation and transparent&lt;/li>
&lt;/ul>
&lt;h3 id="png--portable-network-graphics">
 PNG(Portable Network Graphics)
 &lt;a class="heading-link" href="#png--portable-network-graphics">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h3>
&lt;ul>
&lt;li>high quality&lt;/li>
&lt;li>support transparent&lt;/li>
&lt;li>suitable for web&lt;/li>
&lt;li>not ideal for print&lt;/li>
&lt;/ul>
&lt;h3 id="jpeg--joint-photographic-experts-group">
 JPEG(Joint Photographic Experts Group)
 &lt;a class="heading-link" href="#jpeg--joint-photographic-experts-group">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h3>
&lt;ul>
&lt;li>lossy compression&lt;/li>
&lt;li>multiple colors, ideal for photographs&lt;/li>
&lt;li>good for web&lt;/li>
&lt;/ul>
&lt;h3 id="tiff--tagged-image-file-format">
 TIFF(Tagged Image File Format)
 &lt;a class="heading-link" href="#tiff--tagged-image-file-format">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h3>
&lt;ul>
&lt;li>best quality&lt;/li>
&lt;li>support layers, transparency.&lt;/li>
&lt;li>for professional photography or print&lt;/li>
&lt;li>too large&lt;/li>
&lt;/ul>
&lt;h2 id="vector">
 Vector
 &lt;a class="heading-link" href="#vector">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h2>
&lt;h3 id="eps--encapsulated-postscript">
 EPS(Encapsulated PostScript)
 &lt;a class="heading-link" href="#eps--encapsulated-postscript">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h3>
&lt;ul>
&lt;li>common used in printing and design&lt;/li>
&lt;li>scalable without losing quality&lt;/li>
&lt;li>being replaced&lt;/li>
&lt;/ul>
&lt;h3 id="svg--scalable-vector-graphics">
 SVG(Scalable Vector Graphics)
 &lt;a class="heading-link" href="#svg--scalable-vector-graphics">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h3>
&lt;ul>
&lt;li>the same as EPS&lt;/li>
&lt;li>editable with code&lt;/li>
&lt;li>support animation and interactivity&lt;/li>
&lt;/ul>
&lt;h3 id="pdf--portable-document-format">
 PDF(Portable Document Format)
 &lt;a class="heading-link" href="#pdf--portable-document-format">
 &lt;i class="fa-solid fa-link" aria-hidden="true" title="Link to heading">&lt;/i>
 &lt;span class="sr-only">Link to heading&lt;/span>
 &lt;/a>
&lt;/h3>
&lt;p>don&amp;rsquo;t need introductions&lt;/p></description></item><item><title>how to use the ox-hugo</title><link>https://zkazure.github.io/posts/ox-hugo/</link><pubDate>Thu, 06 Mar 2025 00:00:00 +0000</pubDate><guid>https://zkazure.github.io/posts/ox-hugo/</guid><description>&lt;p>add blow at first&lt;/p>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-org" data-lang="org">&lt;span class="line">&lt;span class="cl">&lt;span class="cs">#+hugo_base_dir&lt;/span>&lt;span class="c">: ~/blog&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="cs">#+hugo_section&lt;/span>&lt;span class="c">: /posts/&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="cs">#+hugo_weight&lt;/span>&lt;span class="c">: auto&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="cs">#+hugo_auto_set_lastmod&lt;/span>&lt;span class="c">: t&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;p>add blow in every article you want to public.&lt;/p>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-org" data-lang="org">&lt;span class="line">&lt;span class="cl">&lt;span class="c">:PROPERTIES:
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c">&lt;/span>&lt;span class="cs">:EXPORT_FILE_NAME: this is the file name
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="cs">:EXPORT_DATE: 2025-02-13
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="cs">&lt;/span>&lt;span class="c">:END:&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;p>[//]&lt;/p></description></item></channel></rss>