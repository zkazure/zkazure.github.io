</span></span><span style="display:flex;"><span>            minLength <span style="color:#f92672">=</span> minLength <span style="color:#f92672">&lt;</span> subLength <span style="color:#f92672">?</span> minLength : subLength;
</span></span><span style="display:flex;"><span>            sum <span style="color:#f92672">-=</span> nums[left<span style="color:#f92672">++</span>];
